#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONTACTS_FILE="${CHAT_CONTACTS_FILE:-$ROOT_DIR/contacts.json}"
STORE_DIR="${MATRIX_STORE_DIR:-$HOME/.matrix-store}"
MC_STORE="$STORE_DIR/matrix-commander"

mkdir -p "$MC_STORE"

if [[ -x "$SCRIPT_DIR/moviecrypt" ]]; then
  "$SCRIPT_DIR/moviecrypt"
fi

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Missing dependency: $1"
    exit 1
  }
}

require_cmd jq

get_room() {
  local name="$1"
  jq -r --arg name "$name" '.[$name] // empty' "$CONTACTS_FILE"
}

show_usage() {
  cat <<USAGE
Usage:
  chat contacts
  chat listen
  chat <name>
  chat <name> "message"
USAGE
}

case "${1:-}" in
  contacts)
    jq -r 'to_entries[] | "\(.key) -> \(.value)"' "$CONTACTS_FILE"
    ;;
  listen)
    require_cmd matrix-commander
    matrix-commander --store "$MC_STORE" --listen forever
    ;;
  "")
    show_usage
    ;;
  *)
    contact="$1"
    room_id="$(get_room "$contact")"
    if [[ -z "$room_id" || "$room_id" == "null" || "$room_id" == "!replace_me_roomid:example.com" ]]; then
      echo "Contact '$contact' has no mapped room id in $CONTACTS_FILE"
      echo "Create DM room in Element/iamb, then update contacts.json."
      echo "Tip (matrix-commander): matrix-commander --store \"$MC_STORE\" --create-room --name \"$contact-dm\" --invite @user:example.com"
      exit 2
    fi

    if [[ $# -ge 2 ]]; then
      require_cmd matrix-commander
      shift
      message="$*"
      matrix-commander --store "$MC_STORE" --room "$room_id" --message "$message"
      exit 0
    fi

    require_cmd iamb
    export IAMB_TARGET_ROOM="$room_id"
    echo "Opening iamb. Target contact: $contact ($room_id)."
    echo "Inside iamb, switch/select this room if not auto-focused."
    iamb
    ;;
esac
