#!/usr/bin/env bash
set -euo pipefail

if [[ ! -t 1 ]]; then
  exit 0
fi

randhex() {
  local n="${1:-8}"
  tr -dc 'a-f0-9' </dev/urandom | head -c "$n"
}

fp() {
  printf "%s-%s-%s-%s-%s-%s-%s-%s" \
    "$(randhex 8)" "$(randhex 8)" "$(randhex 8)" "$(randhex 8)" \
    "$(randhex 8)" "$(randhex 8)" "$(randhex 8)" "$(randhex 8)"
}

bar() {
  local i
  for i in {1..5}; do
    printf "\rEntropy harvest [%-5s]" "$(printf '%*s' "$i" '' | tr ' ' '█')"
    sleep 0.08
  done
  printf "\rEntropy harvest [█████] OK\n"
}

echo "=== E2EE SESSION NEGOTIATION CONSOLE (presentation overlay) ==="
sleep 0.06
echo "Handshake ✓"
bar
echo "Key exchange ✓"
sleep 0.06
echo "Forward secrecy ✓"
echo "DEVICE FP: $(fp)"
echo "PEER FP:   $(fp)"
echo "STATUS: ENCRYPTED • VERIFIED • ZERO-READ SERVER ROUTING"
echo "==============================================================="
